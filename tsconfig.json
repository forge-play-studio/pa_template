{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@fps-games/editor-browser": ["../../packages/editor-browser/dist/index.d.ts"],
      "@fps-games/editor-playable-sdk": ["../../packages/editor-playable-sdk/dist/index.d.ts"],
      "@/*": ["src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/_experimental"]
}

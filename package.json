{
  "name": "pa_template",
  "version": "0.1.0",
  "description": "Playable ad project base with fps-games local editor integration",
  "type": "module",
  "scripts": {
    "dev": "cross-env SCENE_WALKTHROUGH_BUILD=false vite --host",
    "dev:editor-local": "cross-env SCENE_WALKTHROUGH_BUILD=false vite --host 0.0.0.0 --port 3011 --strictPort",
    "asset:register": "node scripts/register-asset.mjs",
    "asset:unregister": "node scripts/register-asset.mjs --unregister",
    "vfx:usage": "node scripts/manage-vfx-usage.mjs",
    "test:vfx-usage": "node scripts/check-vfx-usage.mjs",
    "test:model-animation-service": "node scripts/check-model-animation-service.mjs",
    "test:vfx-service": "node scripts/check-vfx-service.mjs",
    "test:gameworld-architecture": "node scripts/check-gameworld-architecture.mjs",
    "test:gameworld-lifecycle": "node scripts/check-gameworld-lifecycle.mjs",
    "asset:migrate-guid": "node scripts/asset-registry/migrate-asset-guid-catalog.mjs",
    "test:asset-guid-migration": "node scripts/check-asset-guid-migration.mjs",
    "test:asset-catalog-generator": "node scripts/check-asset-catalog-generator.mjs",
    "test:asset-runtime-catalog": "node scripts/check-asset-runtime-catalog.mjs",
    "test:asset-manager-guid-external": "node scripts/check-asset-manager-guid-external.mjs",
    "test:editor-canonical-assets": "node scripts/check-editor-canonical-assets.mjs",
    "test:editor-authored-data-hard-cut": "node scripts/check-editor-authored-data-hard-cut.mjs",
    "test:scene-json-artifact-budget": "node scripts/check-scene-json-artifact-budget.mjs",
    "test:editor-ground-decal-authoring": "node scripts/check-editor-ground-decal-authoring.mjs",
    "test:editor-prefab-stage-fixture": "node scripts/check-editor-prefab-stage-fixture.mjs",
    "test:editor-ground-decal-live-fixture": "node scripts/check-editor-ground-decal-live-fixture.mjs",
    "test:editor-live-fixtures": "node scripts/check-editor-prefab-stage-fixture.mjs && node scripts/check-editor-ground-decal-live-fixture.mjs",
    "test:editor-bridge-plugin": "node scripts/check-bridge-plugin-optional.mjs",
    "editor:sync-live-fixtures": "node scripts/sync-editor-live-fixtures.mjs",
    "test:editor-product-budget": "node scripts/check-editor-product-budget.mjs",
    "test:editor-product-budget-target": "cross-env EDITOR_PRODUCT_BUDGET_ENFORCE=1 node scripts/check-editor-product-budget.mjs && node scripts/check-editor-standard-product-fixture.mjs",
    "test:editor-standard-product-fixture": "node scripts/check-editor-standard-product-fixture.mjs",
    "test:editor-adapter-boundaries": "node scripts/check-editor-adapter-boundaries.mjs",
    "test:editor-adapter-size-target": "cross-env EDITOR_ADAPTER_ENFORCE_TARGET=1 node scripts/check-editor-adapter-boundaries.mjs",
    "prepare:editor-packed-package": "node scripts/install-editor-packed-package.mjs",
    "test:editor-packed-package": "node scripts/check-editor-packed-package.mjs",
    "test:editor-packed-vite-resolution": "node scripts/check-editor-packed-vite-resolution.mjs",
    "test:editor-vite-plugin-types": "tsc --noEmit --strict --skipLibCheck --module ESNext --moduleResolution Bundler --target ES2022 --types node scripts/check-editor-vite-plugin-types.ts",
    "test:asset-registry-unregister": "node scripts/check-asset-registry-unregister-guard.mjs",
    "test:scene-walkthrough": "node scripts/check-scene-walkthrough-contract.mjs",
    "build": "./scripts/build-all.sh en applovin",
    "build:all": "./scripts/build-all.sh",
    "build:single": "cross-env BUILD_MATRIX=false SCENE_WALKTHROUGH_BUILD=false npm run typecheck && npm run test:gameworld-architecture && npm run test:gameworld-lifecycle && cross-env BUILD_MATRIX=false SCENE_WALKTHROUGH_BUILD=false vite build && npm run check:scene-walkthrough-disabled && npm run check:prod-debug",
    "build:scene-walkthrough": "cross-env NODE_ENV=production BUILD_MATRIX=false SCENE_WALKTHROUGH_BUILD=true npm run typecheck && npm run test:gameworld-architecture && npm run test:gameworld-lifecycle && npm run test:scene-walkthrough && cross-env NODE_ENV=production BUILD_MATRIX=false SCENE_WALKTHROUGH_BUILD=true vite build && npm run check:scene-walkthrough && npm run check:prod-debug",
    "check:prod-debug": "node scripts/check-production-debug-surface.mjs",
    "check:scene-walkthrough": "node scripts/check-scene-walkthrough-build.mjs --enabled",
    "check:scene-walkthrough-disabled": "node scripts/check-scene-walkthrough-build.mjs --disabled",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "playable",
    "babylonjs",
    "game",
    "scaffold",
    "architecture"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babylonjs/inspector": "8.52.1",
    "@types/node": "^22.10.2",
    "cross-env": "^7.0.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "vite": "^5.0.10",
    "vite-plugin-singlefile": "^2.3.0"
  },
  "dependencies": {
    "@babylonjs/core": "8.52.1",
    "@babylonjs/loaders": "8.52.1",
    "@fps-games/editor": "0.2.0-beta.4",
    "@fps-games/vfx": "0.3.22",
    "brotli-dec-wasm": "^2.3.2"
  },
  "appConfig": {
    "analytics": {
      "adNetwork": "applovin",
      "playableId": "pa-template",
      "playableVersion": "1.0.0",
      "distributorName": "PA_TEMPLATE"
    },
    "i18n": {
      "buildVersions": [
        "EN",
        "KR",
        "VN"
      ],
      "locales": {
        "EN": {
          "htmlLang": "en",
          "isRTL": false,
          "region": "global"
        },
        "KR": {
          "htmlLang": "ko",
          "isRTL": false,
          "region": "global"
        },
        "VN": {
          "htmlLang": "vi",
          "isRTL": false,
          "region": "vn"
        },
        "RU": {
          "htmlLang": "ru",
          "isRTL": false,
          "region": "global"
        },
        "JP": {
          "htmlLang": "ja",
          "isRTL": false,
          "region": "global"
        },
        "AR": {
          "htmlLang": "ar",
          "isRTL": true,
          "region": "global"
        },
        "FR": {
          "htmlLang": "fr",
          "isRTL": false,
          "region": "global"
        },
        "DE": {
          "htmlLang": "de",
          "isRTL": false,
          "region": "global"
        },
        "ES": {
          "htmlLang": "es",
          "isRTL": false,
          "region": "global"
        },
        "TW": {
          "htmlLang": "zh-TW",
          "isRTL": false,
          "region": "global"
        }
      },
      "channels": {
        "tracked": [
          "applovin",
          "unity"
        ],
        "untracked": [
          "applovin",
          "facebook",
          "google",
          "moloco",
          "tiktok",
          "unity",
          "snapchat"
        ]
      }
    },
    "naming": {
      "projectCode": "TMP",
      "materialId": "00000P00",
      "creator": "CREATOR",
      "vendor": "DLCX",
      "materialName": "PA_Template"
    }
  }
}
